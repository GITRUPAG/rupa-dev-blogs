# ================================================
# RUPA.DEV — Environment Variables
# Copy this file to .env.local and fill in values
# ================================================

# Site
NEXT_PUBLIC_SITE_URL=https://rupa.dev

# ── Google Analytics ────────────────────────────
# Get from: https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Algolia Search ──────────────────────────────
# Get from: https://www.algolia.com/account/api-keys
NEXT_PUBLIC_ALGOLIA_APP_ID=3CEDERW0R8
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=49a7630e69346d9bffeb0517ecb9c7d6
ALGOLIA_ADMIN_KEY=YOUR_ADMIN_API_KEY
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=rupa_dev_posts

#write api key 
#9130ee327572766ca79f52fbfc209c3a

# ── Giscus Comments ─────────────────────────────
# Setup at: https://giscus.app
# 1. Enable GitHub Discussions on your repo
# 2. Go to https://giscus.app, enter your repo
# 3. Copy the values below
NEXT_PUBLIC_GISCUS_REPO=your-github-username/your-repo-name
NEXT_PUBLIC_GISCUS_REPO_ID=R_xxxxxxxxxx
NEXT_PUBLIC_GISCUS_CATEGORY=Comments
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_xxxxxxxxxx

# ── Newsletter (Resend) ──────────────────────────
# Get from: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Admin / CRON Protection ─────────────────────
# Random secret to protect /api/index-posts
# Generate: openssl rand -base64 32
CRON_SECRET=your-random-secret-here
